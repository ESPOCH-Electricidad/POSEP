reset;
load amplxl.dll;
model ../../03_operacion_corto_plazo/ampl/01_despacho_economico/dispatch.mod;

table Generators IN "amplxl" "input_dispatch.xlsx" "Generators":
    G <- [GEN], Pmin, Pmax, cvar;

table Periods IN "amplxl" "input_dispatch.xlsx" "Demand":
    T <- [PERIOD], demand;

read table Generators;
read table Periods;

option solver highs;
solve;

display TotalCost, Pg;
